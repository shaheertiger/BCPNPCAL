---
// Google AdSense Ad Unit Component
// Usage: <AdUnit slot="1234567890" format="auto" />

interface Props {
  slot: string;
  format?: "auto" | "horizontal" | "vertical" | "rectangle";
  responsive?: boolean;
  class?: string;
}

const { slot, format = "auto", responsive = true, class: className = "" } = Astro.props;
---

<div class:list={["ad-container my-8 text-center", className]}>
  <div class="text-[10px] text-slate-400 uppercase tracking-widest mb-1">Advertisement</div>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-2128579868272786"
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive={responsive ? "true" : "false"}
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>
