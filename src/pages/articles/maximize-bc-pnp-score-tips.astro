                <p class="text-3xl font-black text-amber-600">53 pts</p>
                <p class="text-xs text-slate-500 mt-1">Strong bracket</p>
              </div>
              <div class="bg-green-50 rounded-2xl p-5 border border-green-100 ring-2 ring-green-200">
                <p class="text-slate-500 text-xs font-bold uppercase tracking-wider mb-2">$70+/hr</p>
                <p class="text-3xl font-black text-green-600">55 pts</p>
