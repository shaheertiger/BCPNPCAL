const title = "Express Entry for Transport Occupations: 2026 Guide";
const description =
    "A complete guide to the 2026 Express Entry priority category for transport occupations. Learn about eligible NOC codes, the 1-year experience requirement, and how to apply for PR.";
---

<ArticleLayout slug="express-entry-transport-occupations-guide-2026" datePublished="2026-02-25" dateModified="2026-02-25" keywords="express entry transport 2026, transport occupations canada PR, truck drivers express entry, pilots canada immigration" title={title} description={description}>
    <article class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6">
        <div class="max-w-3xl mx-auto space-y-8">
            <!-- Header -->
            <header class="space-y-4 text-center">
                <div
                    class="inline-block bg-amber-100 text-amber-800 px-4 py-1 rounded-full text-sm font-bold mb-4 border border-amber-200 shadow-sm"
                >
                    Express Entry 2026
                </div>
                <h1
                    class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight leading-tight mb-6"
                >
                    Express Entry for <span
                        class="bg-gradient-to-r from-amber-600 to-orange-600 bg-clip-text text-transparent"
                        >Transport Occupations</span
                    >
                </h1>
                <p
                    class="text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed mb-8"
