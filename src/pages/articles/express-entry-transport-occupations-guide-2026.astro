                                <td class="px-4 py-3 text-slate-700">Bus driver (NOC 73301)</td>
                                <td class="px-4 py-3 font-bold text-emerald-700">$20–$28/hr</td>
                                <td class="px-4 py-3 text-blue-700 font-bold">30–40</td>
                            </tr>
