<ArticleLayout slug="bc-pnp-2026-allocation-priorities" datePublished="2026-01-29" dateModified="2026-02-09" keywords="BC PNP 2026 allocation, BC PNP nominations 2026, BC PNP priorities" title={title} description={description}>
    <article class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6">
