                            >
                        </div>
                        <div class="flex items-center mb-6 relative z-10">
                            <div
                                class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-700 rounded-full flex items-center justify-center text-white font-bold text-xl shadow-lg"
