            <section>
                <h2 class="text-2xl font-bold text-slate-900 mb-6">Stream-Specific Language Minimums</h2>
                <div class="bg-white rounded-2xl p-8 border border-slate-100 shadow-sm">
                    <ul class="space-y-2 text-slate-700">
                        <li class="flex justify-between border-b border-slate-100 pb-2"><span>Skilled Worker (TEER 0/1)</span><strong>CLB 7</strong></li>
                        <li class="flex justify-between border-b border-slate-100 pb-2"><span>Skilled Worker (TEER 2/3)</span><strong>CLB 4</strong></li>
                        <li class="flex justify-between border-b border-slate-100 pb-2"><span>Tech Stream</span><strong>CLB 5 (CLB 7 for TEER 0/1 roles)</strong></li>
