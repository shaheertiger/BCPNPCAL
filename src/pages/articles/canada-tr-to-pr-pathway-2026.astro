                                <td class="px-4 py-3 font-bold text-emerald-700">~33,000 – 34,000</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-3 font-semibold">Express Entry (CEC)</td>
                                <td class="px-4 py-3">Skilled workers with 1+ yr Canadian experience</td>
                                <td class="px-4 py-3">~6 months</td>
                                <td class="px-4 py-3">No cap (draw-based)</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-3 font-semibold">BC PNP (Skills Immigration)</td>
                                <td class="px-4 py-3">Workers with a qualifying BC job offer</td>
                                <td class="px-4 py-3">3 – 4 months (provincial) + 12 – 18 months (federal)</td>
                                <td class="px-4 py-3">~6,000 – 8,000 / yr (provincial allocation)</td>
                            </tr>
                            <tr>
                                <td class="px-4 py-3 font-semibold">PNP + Express Entry</td>
                                <td class="px-4 py-3">Provincial nominees with high CRS or nomination</td>
                                <td class="px-4 py-3">~6 months after nomination</td>
                                <td class="px-4 py-3">Varies by province</td>
                            </tr>
                        </tbody>
                    </table>
