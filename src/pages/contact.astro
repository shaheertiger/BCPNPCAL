---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Contact Us - BC PNP Calculator";
const description = "Contact the BC PNP Calculator team. Reach our editor for support, corrections, feedback, or advertising inquiries.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: title,
    description: description,
    url: "https://bcpnpcalculator.ca/contact",
    mainEntity: {
      "@type": "Organization",
      name: "BC PNP Calculator",
      url: "https://bcpnpcalculator.ca",
      email: "contact@bcpnpcalculator.ca",
      founder: {
        "@type": "Person",
        name: "Shaheer Ali Khan",
        jobTitle: "Regulated Canadian Immigration Consultant (RCIC)",
        hasCredential: {
          "@type": "EducationalOccupationalCredential",
          credentialCategory: "Regulated Canadian Immigration Consultant (RCIC)",
          identifier: "R816383",
          recognizedBy: {
            "@type": "Organization",
            name: "College of Immigration and Citizenship Consultants (CICC)",
            url: "https://college-ic.ca",
          },
        },
      },
      contactPoint: {
        "@type": "ContactPoint",
        contactType: "Customer Support",
        email: "contact@bcpnpcalculator.ca",
        availableLanguage: "English",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://bcpnpcalculator.ca" },
      { "@type": "ListItem", position: 2, name: "Contact", item: "https://bcpnpcalculator.ca/contact" },
    ],
  },
];
---

<BaseLayout title={title} description={description} canonical="https://bcpnpcalculator.ca/contact" jsonLd={jsonLd} keywords="contact BC PNP Calculator, BC PNP support, immigration calculator help">
  <div class="min-h-screen bg-slate-50 py-16 px-4 sm:px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="text-center mb-12">
        <h1 class="text-4xl font-black text-slate-900 tracking-tight mb-4">Contact Us</h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          We're here to help. Whether you have a question about the calculator, found a bug, spotted something that needs a correction, or want to discuss advertising, a real person reads every message.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Contact Info Card -->
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm h-full">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Get in Touch</h2>
          
          <div class="space-y-8">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-red-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Email Us</h3>
                <p class="text-slate-600 text-sm mb-2">For general inquiries, support, and feedback:</p>
                <a href="mailto:contact@bcpnpcalculator.ca" class="text-red-600 font-bold hover:underline text-lg">contact@bcpnpcalculator.ca</a>
              </div>
            </div>

            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-slate-900 mb-1">Advertising & Privacy</h3>
                <p class="text-slate-600 text-sm">
                  For inquiries related to advertising or data privacy, please reference "Privacy" or "Ads" in your subject line.
                </p>
              </div>
            </div>
            
            <div class="pt-6 border-t border-slate-100">
               <p class="text-xs text-slate-500 leading-relaxed">
                 <strong>Note:</strong> We are unable to provide personal legal immigration advice. Please consult a licensed Regulated Canadian Immigration Consultant (RCIC) or immigration lawyer for case-specific questions.
               </p>
            </div>

          </div>
        </div>

        <!-- FAQ Quick Links -->
        <div class="bg-slate-900 text-white p-8 rounded-[2rem] shadow-lg h-full flex flex-col justify-between">
          <div>
            <h2 class="text-2xl font-bold mb-6">Common Questions</h2>
            <ul class="space-y-4">
              <li>
                <a href="/bc-pnp-calculator" class="group flex items-center justify-between p-4 bg-slate-800 rounded-xl hover:bg-slate-700 transition-colors">
                  <span class="font-medium">How do I calculate my score?</span>
                  <svg class="w-5 h-5 text-slate-400 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </li>
              <li>
                <a href="/bc-pnp-draws" class="group flex items-center justify-between p-4 bg-slate-800 rounded-xl hover:bg-slate-700 transition-colors">
                  <span class="font-medium">When is the next draw?</span>
                  <svg class="w-5 h-5 text-slate-400 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </li>
              <li>
                <a href="/privacy-policy" class="group flex items-center justify-between p-4 bg-slate-800 rounded-xl hover:bg-slate-700 transition-colors">
                  <span class="font-medium">How is my data used?</span>
                  <svg class="w-5 h-5 text-slate-400 group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              </li>
            </ul>
          </div>
          
          <div class="mt-8 pt-6 border-t border-slate-700">
             <p class="text-slate-400 text-sm">
               We typically respond to inquiries within 24-48 business hours.
             </p>
          </div>
        </div>

      </div>

      <!-- Who runs this site -->
      <div class="mt-8 bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
        <h2 class="text-2xl font-bold text-slate-900 mb-4">Who Runs This Site</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          BC PNP Calculator is published and edited by <strong>Shaheer Ali Khan</strong>, a
          Regulated Canadian Immigration Consultant (RCIC) in good standing with the
          College of Immigration and Citizenship Consultants (CICC), registration
          <strong>R816383</strong>. You can verify this registration on the public
          <a href="https://college-ic.ca" rel="noopener" target="_blank" class="text-red-600 font-bold hover:underline">CICC register</a>.
          Read more about why this tool exists on our
          <a href="/about" class="text-red-600 font-bold hover:underline">About page</a>.
        </p>
        <p class="text-slate-600 leading-relaxed">
          Editorial responsibility for the calculator logic, guides, and draw analysis
          on this site rests with the editor named above. Our content is reviewed against
          the official BC PNP program criteria and updated within 24–48 hours of any
          policy change we become aware of.
        </p>
      </div>

      <!-- Editorial standards & corrections -->
      <div class="mt-8 grid md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 mb-4">Corrections & Accuracy</h2>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            Immigration rules change often. If you believe a figure, date, or scoring
            rule on this site is out of date or incorrect, please email us with the page
            URL and what you think should change. We take corrections seriously and will
            update the page or explain our reasoning.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">
            Subject line tip: use <strong>"Correction"</strong> so it reaches the editor faster.
          </p>
        </div>
        <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
          <h2 class="text-xl font-bold text-slate-900 mb-4">What We Can &amp; Can't Do</h2>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            We can help with how the calculator works, how SIRS points are structured,
            and where to find official information.
          </p>
          <p class="text-slate-600 text-sm leading-relaxed">
            We <strong>cannot</strong> give case-specific legal advice or represent you on an
            application through this website. For personal advice, retain a licensed RCIC
            or Canadian immigration lawyer for a formal consultation.
          </p>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>
